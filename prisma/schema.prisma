generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Users ───────────────────────────────────────────────

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  name         String?
  avatarUrl    String?   @map("avatar_url")
  avatar       String    @default("🐻") @map("avatar_emoji")
  xp           Int       @default(0)
  streak       Int       @default(0)
  lives        Int       @default(5)
  level        Int       @default(1)
  lastActiveAt DateTime? @map("last_active_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  progress     UserProgress[]
  wrongAnswers UserWrongAnswer[]
  testSessions TestSession[]
  @@map("users")
}

// ─── Content hierarchy: World > Unit > Lesson > Exercise ─

model World {
  id          String @id @default(uuid())
  title       String
  description String
  icon        String @default("globe")
  color       String @default("#4F46E5")
  order       Int    @default(0)

  units Unit[]
  @@map("worlds")
}

model Unit {
  id      String @id @default(uuid())
  worldId String @map("world_id")
  title   String
  order   Int    @default(0)

  world   World    @relation(fields: [worldId], references: [id], onDelete: Cascade)
  lessons Lesson[]
  @@map("units")
}

model Lesson {
  id       String @id @default(uuid())
  unitId   String @map("unit_id")
  title    String
  order    Int    @default(0)
  xpReward Int    @default(10) @map("xp_reward")

  unit       Unit           @relation(fields: [unitId], references: [id], onDelete: Cascade)
  exercises  Exercise[]
  progress   UserProgress[]
  @@map("lessons")
}

enum ExerciseType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  FILL_BLANK
  MATCH_PAIRS
  ORDER
}

model Exercise {
  id          String       @id @default(uuid())
  lessonId    String       @map("lesson_id")
  type        ExerciseType
  question    String
  explanation String       @default("")
  order       Int          @default(0)

  lesson  Lesson           @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  options ExerciseOption[]
  @@map("exercises")
}

model ExerciseOption {
  id         String  @id @default(uuid())
  exerciseId String  @map("exercise_id")
  text       String
  isCorrect  Boolean @default(false) @map("is_correct")
  order      Int     @default(0)

  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  @@map("exercise_options")
}

// ─── Progress ────────────────────────────────────────────

model UserProgress {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  lessonId        String   @map("lesson_id")
  completed       Boolean  @default(false)
  score           Int      @default(0)
  bestScore       Int      @default(0) @map("best_score")
  timesAttempted  Int      @default(0) @map("times_attempted")
  theoryCompleted Boolean  @default(false) @map("theory_completed")
  createdAt       DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@map("user_progress")
}

model UserWrongAnswer {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  exerciseId String   @map("exercise_id")
  lessonId   String   @map("lesson_id")
  timesWrong Int      @default(1) @map("times_wrong")
  lastSeenAt DateTime @default(now()) @map("last_seen_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, exerciseId])
  @@map("user_wrong_answers")
}

model TestSession {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  lessonId   String   @map("lesson_id")
  score      Int      @default(0)
  totalQ     Int      @default(10) @map("total_questions")
  completed  Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("test_sessions")
}
